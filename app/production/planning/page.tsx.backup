'use client';

import { useState, useEffect } from 'react';
import { useRouter } from 'next/navigation';
import {
  Search,
  RefreshCw,
  Download,
  Loader2,
  FileText,
  AlertTriangle,
  Plus,
  Calendar,
  Package,
  LayoutGrid,
  List,
  Clock,
  CheckCircle2,
  AlertCircle,
  PlayCircle,
  Box,
  ChevronLeft,
  ChevronRight,
  TrendingUp,
  X,
  Trash2,
  Check,
} from 'lucide-react';
import { PermissionGuard } from '@/components/auth/PermissionGuard';
import Button from '@/components/ui/Button';
import Badge from '@/components/ui/Badge';
import {
  useProductionPlans,
  useSkusWithBom,
  useProductionPlanMutations,
  useBomCalculation,
} from '@/hooks/useProductionPlanning';
import {
  ProductionPlanWithItems,
  ProductionPlanStatus,
  ProductionPlanItem,
  CreateProductionPlanInput,
  CreateProductionPlanItemInput,
  CalculatedMaterial,
} from '@/types/production-planning-schema';

const ProductionPlanningPage = () => {
  const router = useRouter();

  // View mode state
  const [viewMode, setViewMode] = useState<'grid' | 'list' | 'calendar'>('grid');

  // Calendar state
  const [currentMonth, setCurrentMonth] = useState(new Date());

  // Filters
  const [searchTerm, setSearchTerm] = useState('');
  const [selectedDate, setSelectedDate] = useState('');
  const [selectedStatus, setSelectedStatus] = useState<ProductionPlanStatus | 'all'>('all');

  // Modal state
  const [showCreateModal, setShowCreateModal] = useState(false);
  const [selectedPlan, setSelectedPlan] = useState<ProductionPlanWithItems | null>(null);

  // Fetch data
  const { plans, isLoading, error, summary, mutate } = useProductionPlans({
    search: searchTerm,
    status: selectedStatus,
    start_date: selectedDate || undefined,
  });

  const getStatusConfig = (status: string) => {
    switch (status) {
      case 'draft':
        return {
          badge: <Badge variant="default" size="sm"><span className="text-[10px]">ร่าง</span></Badge>,
          icon: <Clock className="w-4 h-4 text-gray-500" />,
          color: 'bg-gray-50 border-gray-200',
          textColor: 'text-gray-700'
        };
      case 'approved':
        return {
          badge: <Badge variant="info" size="sm"><span className="text-[10px]">อนุมัติแล้ว</span></Badge>,
          icon: <CheckCircle2 className="w-4 h-4 text-blue-500" />,
          color: 'bg-blue-50 border-blue-200',
          textColor: 'text-blue-700'
        };
      case 'in_production':
        return {
          badge: <Badge variant="warning" size="sm"><span className="text-[10px]">กำลังผลิต</span></Badge>,
          icon: <PlayCircle className="w-4 h-4 text-orange-500" />,
          color: 'bg-orange-50 border-orange-200',
          textColor: 'text-orange-700'
        };
      case 'completed':
        return {
          badge: <Badge variant="success" size="sm"><span className="text-[10px]">เสร็จสิ้น</span></Badge>,
          icon: <CheckCircle2 className="w-4 h-4 text-green-500" />,
          color: 'bg-green-50 border-green-200',
          textColor: 'text-green-700'
        };
      case 'cancelled':
        return {
          badge: <Badge variant="danger" size="sm"><span className="text-[10px]">ยกเลิก</span></Badge>,
          icon: <AlertCircle className="w-4 h-4 text-red-500" />,
          color: 'bg-red-50 border-red-200',
          textColor: 'text-red-700'
        };
      default:
        return {
          badge: <Badge variant="default" size="sm"><span className="text-[10px]">{status}</span></Badge>,
          icon: <Clock className="w-4 h-4 text-gray-500" />,
          color: 'bg-gray-50 border-gray-200',
          textColor: 'text-gray-700'
        };
    }
  };

  // Calendar helper functions
  const getDaysInMonth = (date: Date) => {
    const year = date.getFullYear();
    const month = date.getMonth();
    const firstDay = new Date(year, month, 1);
    const lastDay = new Date(year, month + 1, 0);
    const daysInMonth = lastDay.getDate();
    const startingDayOfWeek = firstDay.getDay();
    return { daysInMonth, startingDayOfWeek, year, month };
  };

  const getPlansByDate = (date: string) => {
    return plans.filter(plan => plan.plan_start_date <= date && plan.plan_end_date >= date);
  };

  const navigateMonth = (direction: 'prev' | 'next') => {
    setCurrentMonth(prev => {
      const newDate = new Date(prev);
      if (direction === 'prev') {
        newDate.setMonth(newDate.getMonth() - 1);
      } else {
        newDate.setMonth(newDate.getMonth() + 1);
      }
      return newDate;
    });
  };

  const goToToday = () => {
    setCurrentMonth(new Date());
  };

  return (
    <div className="h-[calc(100vh-3.25rem)] bg-gradient-to-br from-blue-50 via-white to-indigo-50 overflow-hidden">
      <div className="h-full flex flex-col space-y-3 pt-2 px-3 pb-2">

        {/* Header Section */}
        <div className="bg-white/90 backdrop-blur-sm border-2 border-primary-100 rounded-xl px-4 py-3 shadow-lg flex-shrink-0">
          <div className="flex items-center justify-between">
            <div className="flex items-center gap-3">
              <div className="w-12 h-12 bg-gradient-to-br from-primary-500 to-primary-600 rounded-xl flex items-center justify-center shadow-md">
                <Box className="w-6 h-6 text-white" />
              </div>
              <div>
                <h1 className="text-xl font-bold text-gray-900 font-thai">แผนการผลิต</h1>
                <p className="text-xs text-gray-500 font-thai mt-0.5">Production Planning</p>
              </div>
            </div>
            <div className="flex items-center gap-2">
              <Button variant="outline" size="sm" icon={Download} className="text-xs">
                Export
              </Button>
              <Button
                variant="outline"
                size="sm"
                icon={TrendingUp}
                className="text-xs"
                onClick={() => router.push('/production/forecast')}
              >
                ยอดประมาณการณ์
              </Button>
              <Button
                variant="primary"
                size="sm"
                icon={Plus}
                className="text-xs font-semibold"
                onClick={() => setShowCreateModal(true)}
              >
                สร้างแผนใหม่
              </Button>
            </div>
          </div>
        </div>

        {/* Filters & Controls */}
        <div className="bg-white/80 backdrop-blur-sm border border-gray-200 rounded-xl px-3 py-2 shadow-sm flex-shrink-0">
          <div className="flex items-center gap-2">
            <div className="flex-1 relative">
              <Search className="absolute left-2.5 top-1/2 transform -translate-y-1/2 w-4 h-4 text-gray-400" />
              <input
                type="text"
                value={searchTerm}
                onChange={(e) => setSearchTerm(e.target.value)}
                placeholder="ค้นหาด้วย รหัสแผน, ชื่อแผน..."
                className="w-full pl-9 pr-3 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm font-thai focus:outline-none focus:ring-2 focus:ring-primary-500/50 focus:border-primary-500"
              />
            </div>
            <div className="flex items-center gap-2">
              <Calendar className="w-4 h-4 text-gray-400" />
              <input
                type="date"
                value={selectedDate}
                onChange={(e) => setSelectedDate(e.target.value)}
                className="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm font-thai focus:outline-none focus:ring-2 focus:ring-primary-500/50 w-36"
              />
            </div>
            <select
              value={selectedStatus}
              onChange={(e) => setSelectedStatus(e.target.value as ProductionPlanStatus | 'all')}
              className="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm font-thai focus:outline-none focus:ring-2 focus:ring-primary-500/50"
            >
              <option value="all">ทุกสถานะ</option>
              <option value="draft">ร่าง</option>
              <option value="approved">อนุมัติแล้ว</option>
              <option value="in_production">กำลังผลิต</option>
              <option value="completed">เสร็จสิ้น</option>
              <option value="cancelled">ยกเลิก</option>
            </select>

            {/* View Toggle */}
            <div className="flex items-center gap-1 bg-gray-100 rounded-lg p-1">
              <button
                onClick={() => setViewMode('grid')}
                className={`p-1.5 rounded transition-colors ${
                  viewMode === 'grid' ? 'bg-white text-primary-600 shadow-sm' : 'text-gray-500 hover:text-gray-700'
                }`}
                title="มุมมองกริด"
              >
                <LayoutGrid className="w-4 h-4" />
              </button>
              <button
                onClick={() => setViewMode('list')}
                className={`p-1.5 rounded transition-colors ${
                  viewMode === 'list' ? 'bg-white text-primary-600 shadow-sm' : 'text-gray-500 hover:text-gray-700'
                }`}
                title="มุมมองรายการ"
              >
                <List className="w-4 h-4" />
              </button>
              <button
                onClick={() => setViewMode('calendar')}
                className={`p-1.5 rounded transition-colors ${
                  viewMode === 'calendar' ? 'bg-white text-primary-600 shadow-sm' : 'text-gray-500 hover:text-gray-700'
                }`}
                title="มุมมองปฏิทิน"
              >
                <Calendar className="w-4 h-4" />
              </button>
            </div>

            <Button variant="outline" size="sm" icon={RefreshCw} onClick={() => mutate()} disabled={isLoading} className="text-xs">
              รีเฟรช
            </Button>
          </div>
        </div>

        {/* Planning Board */}
        <div className="flex-1 min-h-0 overflow-auto">
          {isLoading ? (
            <div className="h-full flex flex-col items-center justify-center text-gray-500 gap-3">
              <Loader2 className="w-8 h-8 animate-spin text-primary-500" />
              <p className="text-sm font-thai">กำลังโหลดแผนการผลิต...</p>
            </div>
          ) : error ? (
            <div className="h-full flex flex-col items-center justify-center text-red-500 gap-2">
              <AlertTriangle className="w-12 h-12" />
              <p className="text-sm font-thai">{error}</p>
            </div>
          ) : plans.length === 0 && viewMode !== 'calendar' ? (
            <div className="h-full flex flex-col items-center justify-center text-gray-400 gap-4">
              <FileText className="w-16 h-16" />
              <div className="text-center">
                <p className="text-base font-semibold font-thai text-gray-600">ไม่พบแผนการผลิต</p>
                <p className="text-sm text-gray-400 mt-1 font-thai">ลองปรับเปลี่ยนตัวกรองหรือสร้างแผนใหม่</p>
              </div>
            </div>
          ) : viewMode === 'calendar' ? (
            <CalendarView
              plans={plans}
              currentMonth={currentMonth}
              onNavigateMonth={navigateMonth}
              onGoToToday={goToToday}
              getStatusConfig={getStatusConfig}
              getPlansByDate={getPlansByDate}
              getDaysInMonth={getDaysInMonth}
              onPlanClick={setSelectedPlan}
            />
          ) : viewMode === 'grid' ? (
            <GridView plans={plans} getStatusConfig={getStatusConfig} onPlanClick={setSelectedPlan} />
          ) : (
            <ListView plans={plans} getStatusConfig={getStatusConfig} onPlanClick={setSelectedPlan} />
          )}
        </div>
      </div>

      {/* Create Plan Modal */}
      {showCreateModal && (
        <CreatePlanModal
          onClose={() => setShowCreateModal(false)}
          onSuccess={() => {
            setShowCreateModal(false);
            mutate();
          }}
        />
      )}

      {/* Plan Detail Modal */}
      {selectedPlan && (
        <PlanDetailModal
          plan={selectedPlan}
          onClose={() => setSelectedPlan(null)}
          getStatusConfig={getStatusConfig}
        />
      )}
    </div>
  );
};

// Grid View Component
function GridView({ plans, getStatusConfig, onPlanClick }: { plans: ProductionPlanWithItems[]; getStatusConfig: (status: string) => any; onPlanClick: (plan: ProductionPlanWithItems) => void }) {
  const statusColumns = [
    { status: 'draft', title: 'ร่าง', subtitle: 'Draft', icon: Clock, gradient: 'from-gray-400 to-gray-500', bgColor: 'bg-gray-50', borderColor: 'border-gray-200', countBg: 'bg-gray-100 text-gray-600' },
    { status: 'approved', title: 'อนุมัติแล้ว', subtitle: 'Approved', icon: CheckCircle2, gradient: 'from-blue-500 to-blue-600', bgColor: 'bg-blue-50', borderColor: 'border-blue-200', countBg: 'bg-blue-100 text-blue-700' },
    { status: 'in_production', title: 'กำลังผลิต', subtitle: 'In Production', icon: PlayCircle, gradient: 'from-orange-500 to-amber-500', bgColor: 'bg-orange-50', borderColor: 'border-orange-200', countBg: 'bg-orange-100 text-orange-700' },
    { status: 'completed', title: 'เสร็จสิ้น', subtitle: 'Completed', icon: CheckCircle2, gradient: 'from-emerald-500 to-green-500', bgColor: 'bg-emerald-50', borderColor: 'border-emerald-200', countBg: 'bg-emerald-100 text-emerald-700' },
  ];

  return (
    <div className="h-full">
      <div className="grid grid-cols-4 gap-4 h-full pb-4">
        {statusColumns.map((column) => {
          const columnPlans = plans.filter(p => p.status === column.status);
          const IconComponent = column.icon;

          return (
            <div key={column.status} className="flex flex-col min-h-0">
              <div className={`bg-gradient-to-r ${column.gradient} rounded-t-xl px-4 py-3 shadow-sm`}>
                <div className="flex items-center justify-between">
                  <div className="flex items-center gap-2">
                    <div className="w-8 h-8 bg-white/20 rounded-lg flex items-center justify-center">
                      <IconComponent className="w-4 h-4 text-white" />
                    </div>
                    <div>
                      <h3 className="text-sm font-bold text-white font-thai">{column.title}</h3>
                      <p className="text-[10px] text-white/70">{column.subtitle}</p>
                    </div>
                  </div>
                  <div className={`px-2.5 py-1 rounded-full text-xs font-bold ${column.countBg}`}>
                    {columnPlans.length}
                  </div>
                </div>
              </div>

              <div className={`flex-1 ${column.bgColor} border-2 ${column.borderColor} border-t-0 rounded-b-xl p-3 overflow-y-auto thin-scrollbar`}>
                {columnPlans.length === 0 ? (
                  <div className="h-full flex flex-col items-center justify-center text-gray-400 py-8">
                    <div className="w-12 h-12 rounded-full bg-gray-100 flex items-center justify-center mb-3">
                      <FileText className="w-6 h-6 text-gray-300" />
                    </div>
                    <p className="text-xs font-thai text-center">ไม่มีแผนในสถานะนี้</p>
                  </div>
                ) : (
                  <div className="space-y-3">
                    {columnPlans.map((plan) => (
                      <PlanCard key={plan.plan_id} plan={plan} onClick={() => onPlanClick(plan)} />
                    ))}
                  </div>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  );
}

// Plan Card Component
function PlanCard({ plan, onClick }: { plan: ProductionPlanWithItems; onClick: () => void }) {
  const itemCount = plan.items?.length || 0;

  return (
    <div 
      className="bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-md transition-all cursor-pointer group"
      onClick={onClick}
    >
      <div className="px-3 py-2.5 border-b border-gray-100">
        <div className="flex items-center justify-between mb-1">
          <span className="font-mono text-xs font-bold text-blue-600 bg-blue-50 px-2 py-0.5 rounded">
            {plan.plan_no}
          </span>
          <span className="text-[10px] text-gray-500 font-thai">
            {new Date(plan.plan_start_date).toLocaleDateString('th-TH', { day: '2-digit', month: 'short' })}
          </span>
        </div>
        <h4 className="text-sm font-semibold text-gray-900 font-thai line-clamp-2 group-hover:text-blue-600 transition-colors">
          {plan.plan_name}
        </h4>
      </div>

      <div className="px-3 py-2.5 space-y-2">
        <div className="flex items-center gap-2 text-xs text-gray-600">
          <Package className="w-3.5 h-3.5 text-purple-500" />
          <span className="font-thai">{itemCount} รายการสินค้า</span>
        </div>

        <div className="flex items-center justify-between pt-2 border-t border-gray-100">
          <div className="flex items-center gap-1">
            <span className="text-xs text-gray-500 font-thai">วัตถุดิบ:</span>
            <span className="text-sm font-bold text-gray-900">{plan.total_materials_required}</span>
          </div>
          {plan.total_shortage_items > 0 && (
            <div className="flex items-center gap-1 bg-red-50 px-2 py-0.5 rounded">
              <AlertTriangle className="w-3 h-3 text-red-500" />
              <span className="text-xs font-semibold text-red-700">{plan.total_shortage_items} ขาด</span>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}


// List View Component
function ListView({ plans, getStatusConfig, onPlanClick }: { plans: ProductionPlanWithItems[]; getStatusConfig: (status: string) => any; onPlanClick: (plan: ProductionPlanWithItems) => void }) {
  return (
    <div className="bg-white rounded-xl shadow-sm border border-gray-200">
      <div className="overflow-x-auto thin-scrollbar">
        <table className="w-full table-fixed text-sm">
          <thead className="sticky top-0 bg-gradient-to-r from-gray-50 to-gray-100 z-10 border-b border-gray-200">
            <tr>
              <th className="px-3 py-2.5 text-left text-xs font-semibold text-gray-700 uppercase tracking-wide border-r border-gray-200 w-[12%]">รหัสแผน</th>
              <th className="px-3 py-2.5 text-left text-xs font-semibold text-gray-700 uppercase tracking-wide border-r border-gray-200 w-[20%]">ชื่อแผน</th>
              <th className="px-3 py-2.5 text-left text-xs font-semibold text-gray-700 uppercase tracking-wide border-r border-gray-200 w-[12%]">วันที่เริ่ม</th>
              <th className="px-3 py-2.5 text-left text-xs font-semibold text-gray-700 uppercase tracking-wide border-r border-gray-200 w-[12%]">วันที่สิ้นสุด</th>
              <th className="px-3 py-2.5 text-center text-xs font-semibold text-gray-700 uppercase tracking-wide border-r border-gray-200 w-[10%]">สินค้า</th>
              <th className="px-3 py-2.5 text-center text-xs font-semibold text-gray-700 uppercase tracking-wide border-r border-gray-200 w-[10%]">วัตถุดิบ</th>
              <th className="px-3 py-2.5 text-center text-xs font-semibold text-gray-700 uppercase tracking-wide border-r border-gray-200 w-[10%]">ขาด</th>
              <th className="px-3 py-2.5 text-left text-xs font-semibold text-gray-700 uppercase tracking-wide w-[14%]">สถานะ</th>
            </tr>
          </thead>
          <tbody>
            {plans.map((plan) => {
              const statusConfig = getStatusConfig(plan.status);
              return (
                <tr key={plan.plan_id} className="border-b border-gray-100 hover:bg-blue-50/30 transition-colors cursor-pointer" onClick={() => onPlanClick(plan)}>
                  <td className="px-3 py-2 text-xs font-mono font-semibold text-blue-700">{plan.plan_no}</td>
                  <td className="px-3 py-2 text-xs font-thai text-gray-900">{plan.plan_name}</td>
                  <td className="px-3 py-2 text-xs text-gray-700 font-thai">
                    {new Date(plan.plan_start_date).toLocaleDateString('th-TH', { day: '2-digit', month: '2-digit', year: 'numeric' })}
                  </td>
                  <td className="px-3 py-2 text-xs text-gray-700 font-thai">
                    {new Date(plan.plan_end_date).toLocaleDateString('th-TH', { day: '2-digit', month: '2-digit', year: 'numeric' })}
                  </td>
                  <td className="px-3 py-2 text-center">
                    <span className="text-sm font-bold text-purple-600">{plan.total_products_planned}</span>
                  </td>
                  <td className="px-3 py-2 text-center">
                    <span className="text-sm font-bold text-blue-600">{plan.total_materials_required}</span>
                  </td>
                  <td className="px-3 py-2 text-center">
                    {plan.total_shortage_items > 0 ? (
                      <span className="text-sm font-bold text-red-600">{plan.total_shortage_items}</span>
                    ) : (
                      <span className="text-sm text-gray-400">-</span>
                    )}
                  </td>
                  <td className="px-3 py-2">{statusConfig.badge}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  );
}

// Calendar View Component
function CalendarView({
  plans,
  currentMonth,
  onNavigateMonth,
  onGoToToday,
  getStatusConfig,
  getPlansByDate,
  getDaysInMonth,
  onPlanClick,
}: {
  plans: ProductionPlanWithItems[];
  currentMonth: Date;
  onNavigateMonth: (direction: 'prev' | 'next') => void;
  onGoToToday: () => void;
  getStatusConfig: (status: string) => any;
  getPlansByDate: (date: string) => ProductionPlanWithItems[];
  getDaysInMonth: (date: Date) => { daysInMonth: number; startingDayOfWeek: number; year: number; month: number };
  onPlanClick: (plan: ProductionPlanWithItems) => void;
}) {
  return (
    <div className="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
      <div className="flex items-center justify-between mb-4 pb-3 border-b border-gray-200">
        <div className="flex items-center gap-3">
          <button onClick={() => onNavigateMonth('prev')} className="p-2 hover:bg-gray-100 rounded-lg transition-colors" title="เดือนก่อนหน้า">
            <ChevronLeft className="w-5 h-5 text-gray-600" />
          </button>
          <h2 className="text-lg font-bold text-gray-900 font-thai min-w-[180px] text-center">
            {currentMonth.toLocaleDateString('th-TH', { month: 'long', year: 'numeric' })}
          </h2>
          <button onClick={() => onNavigateMonth('next')} className="p-2 hover:bg-gray-100 rounded-lg transition-colors" title="เดือนถัดไป">
            <ChevronRight className="w-5 h-5 text-gray-600" />
          </button>
        </div>
        <button onClick={onGoToToday} className="px-3 py-1.5 text-xs font-thai bg-primary-500 text-white rounded-lg hover:bg-primary-600 transition-colors">
          วันนี้
        </button>
      </div>

      <div className="grid grid-cols-7 gap-2">
        {['อา', 'จ', 'อ', 'พ', 'พฤ', 'ศ', 'ส'].map((day) => (
          <div key={day} className="text-center font-semibold text-sm text-gray-600 font-thai py-2">{day}</div>
        ))}

        {(() => {
          const { daysInMonth, startingDayOfWeek, year, month } = getDaysInMonth(currentMonth);
          const days = [];

          for (let i = 0; i < startingDayOfWeek; i++) {
            days.push(<div key={`empty-${i}`} className="min-h-[100px] bg-gray-50 rounded-lg" />);
          }

          for (let day = 1; day <= daysInMonth; day++) {
            const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
            const dayPlans = getPlansByDate(dateStr);
            const isToday = new Date().toDateString() === new Date(year, month, day).toDateString();

            days.push(
              <div
                key={day}
                className={`min-h-[100px] bg-white border-2 rounded-lg p-2 transition-all hover:shadow-md ${
                  isToday ? 'border-primary-500 bg-primary-50' : 'border-gray-200'
                }`}
              >
                <div className={`text-sm font-semibold mb-2 ${isToday ? 'text-primary-600' : 'text-gray-700'}`}>{day}</div>
                <div className="space-y-1">
                  {dayPlans.slice(0, 3).map((plan) => {
                    const statusConfig = getStatusConfig(plan.status);
                    return (
                      <div
                        key={plan.plan_id}
                        className={`text-[10px] font-thai px-1.5 py-1 rounded border ${statusConfig.color} cursor-pointer hover:shadow-sm transition-shadow`}
                        title={`${plan.plan_no} - ${plan.plan_name}`}
                        onClick={(e) => { e.stopPropagation(); onPlanClick(plan); }}
                      >
                        <div className="flex items-center gap-1 mb-0.5">
                          {statusConfig.icon}
                          <span className="font-mono font-semibold truncate">{plan.plan_no}</span>
                        </div>
                        <div className="truncate text-gray-600">{plan.plan_name}</div>
                      </div>
                    );
                  })}
                  {dayPlans.length > 3 && (
                    <div className="text-[10px] text-center text-gray-500 font-thai py-1">+{dayPlans.length - 3} เพิ่มเติม</div>
                  )}
                </div>
              </div>
            );
          }

          return days;
        })()}
      </div>
    </div>
  );
}

// Plan Detail Modal Component
function PlanDetailModal({ 
  plan, 
  onClose, 
  getStatusConfig 
}: { 
  plan: ProductionPlanWithItems; 
  onClose: () => void; 
  getStatusConfig: (status: string) => any;
}) {
  const statusConfig = getStatusConfig(plan.status);

  return (
    <div className="fixed inset-0 bg-black/50 flex items-center justify-center z-50">
      <div className="bg-white rounded-xl shadow-xl w-full max-w-4xl max-h-[90vh] overflow-hidden">
        {/* Header */}
        <div className="flex items-center justify-between px-6 py-4 border-b border-gray-200 bg-gradient-to-r from-primary-500 to-primary-600">
          <div className="flex items-center gap-3">
            <div className="w-10 h-10 bg-white/20 rounded-lg flex items-center justify-center">
              <FileText className="w-5 h-5 text-white" />
            </div>
            <div>
              <h2 className="text-lg font-bold text-white font-thai">รายละเอียดแผนการผลิต</h2>
              <p className="text-xs text-white/80 font-mono">{plan.plan_no}</p>
            </div>
          </div>
          <button onClick={onClose} className="p-1 hover:bg-white/20 rounded-lg transition-colors">
            <X className="w-5 h-5 text-white" />
          </button>
        </div>

        {/* Content */}
        <div className="p-6 overflow-y-auto max-h-[calc(90vh-140px)]">
          {/* Plan Info */}
          <div className="grid grid-cols-2 gap-6 mb-6">
            <div className="space-y-4">
              <div>
                <label className="block text-xs text-gray-500 font-thai mb-1">ชื่อแผน</label>
                <p className="text-sm font-semibold text-gray-900 font-thai">{plan.plan_name}</p>
              </div>
              {plan.plan_description && (
                <div>
                  <label className="block text-xs text-gray-500 font-thai mb-1">รายละเอียด</label>
                  <p className="text-sm text-gray-700 font-thai">{plan.plan_description}</p>
                </div>
              )}
              <div>
                <label className="block text-xs text-gray-500 font-thai mb-1">สถานะ</label>
                <div className="flex items-center gap-2">
                  {statusConfig.icon}
                  {statusConfig.badge}
                </div>
              </div>
            </div>
            <div className="space-y-4">
              <div className="grid grid-cols-2 gap-4">
                <div>
                  <label className="block text-xs text-gray-500 font-thai mb-1">วันที่เริ่ม</label>
                  <p className="text-sm font-semibold text-gray-900">
                    {new Date(plan.plan_start_date).toLocaleDateString('th-TH', { day: '2-digit', month: 'long', year: 'numeric' })}
                  </p>
                </div>
                <div>
                  <label className="block text-xs text-gray-500 font-thai mb-1">วันที่สิ้นสุด</label>
                  <p className="text-sm font-semibold text-gray-900">
                    {new Date(plan.plan_end_date).toLocaleDateString('th-TH', { day: '2-digit', month: 'long', year: 'numeric' })}
                  </p>
                </div>
              </div>
              <div className="grid grid-cols-3 gap-4">
                <div className="bg-purple-50 rounded-lg p-3 text-center">
                  <p className="text-xs text-purple-600 font-thai">สินค้า</p>
                  <p className="text-xl font-bold text-purple-700">{plan.total_products_planned}</p>
                </div>
                <div className="bg-blue-50 rounded-lg p-3 text-center">
                  <p className="text-xs text-blue-600 font-thai">วัตถุดิบ</p>
                  <p className="text-xl font-bold text-blue-700">{plan.total_materials_required}</p>
                </div>
                <div className={`rounded-lg p-3 text-center ${plan.total_shortage_items > 0 ? 'bg-red-50' : 'bg-green-50'}`}>
                  <p className={`text-xs font-thai ${plan.total_shortage_items > 0 ? 'text-red-600' : 'text-green-600'}`}>ขาด</p>
                  <p className={`text-xl font-bold ${plan.total_shortage_items > 0 ? 'text-red-700' : 'text-green-700'}`}>
                    {plan.total_shortage_items}
                  </p>
                </div>
              </div>
            </div>
          </div>

          {/* Items List */}
          {plan.items && plan.items.length > 0 && (
            <div>
              <h3 className="text-sm font-semibold text-gray-700 font-thai mb-3 flex items-center gap-2">
                <Package className="w-4 h-4 text-purple-500" />
                รายการสินค้าที่ต้องผลิต ({plan.items.length} รายการ)
              </h3>
              <div className="bg-gray-50 rounded-lg border border-gray-200 overflow-hidden">
                <table className="w-full text-sm">
                  <thead className="bg-gray-100 border-b border-gray-200">
                    <tr>
                      <th className="px-4 py-2 text-left text-xs font-semibold text-gray-600 font-thai">SKU</th>
                      <th className="px-4 py-2 text-left text-xs font-semibold text-gray-600 font-thai">ชื่อสินค้า</th>
                      <th className="px-4 py-2 text-right text-xs font-semibold text-gray-600 font-thai">จำนวน</th>
                      <th className="px-4 py-2 text-center text-xs font-semibold text-gray-600 font-thai">สถานะ</th>
                    </tr>
                  </thead>
                  <tbody>
                    {plan.items.map((item, index) => {
                      const itemWithSku = item as ProductionPlanItem & { sku?: { sku_id: string; sku_name: string } };
                      return (
                        <tr key={item.plan_item_id || index} className="border-b border-gray-100 last:border-0">
                          <td className="px-4 py-2 font-mono text-xs text-blue-600">{item.sku_id}</td>
                          <td className="px-4 py-2 text-xs text-gray-900 font-thai">{itemWithSku.sku?.sku_name || item.sku_id}</td>
                          <td className="px-4 py-2 text-right text-xs font-bold text-gray-900">{item.required_qty?.toLocaleString()}</td>
                          <td className="px-4 py-2 text-center">
                            {item.status === 'completed' ? (
                              <span className="inline-flex items-center gap-1 text-xs text-green-600 bg-green-50 px-2 py-0.5 rounded">
                                <CheckCircle2 className="w-3 h-3" />
                                เสร็จ
                              </span>
                            ) : item.status === 'in_progress' ? (
                              <span className="inline-flex items-center gap-1 text-xs text-orange-600 bg-orange-50 px-2 py-0.5 rounded">
                                <PlayCircle className="w-3 h-3" />
                                กำลังผลิต
                              </span>
                            ) : (
                              <span className="inline-flex items-center gap-1 text-xs text-gray-500 bg-gray-100 px-2 py-0.5 rounded">
                                <Clock className="w-3 h-3" />
                                รอดำเนินการ
                              </span>
                            )}
                          </td>
                        </tr>
                      );
                    })}
                  </tbody>
                </table>
              </div>
            </div>
          )}

          {/* Created/Updated Info */}
          <div className="mt-6 pt-4 border-t border-gray-200 flex items-center justify-between text-xs text-gray-500">
            <span className="font-thai">
              สร้างเมื่อ: {new Date(plan.created_at).toLocaleString('th-TH')}
            </span>
            {plan.updated_at && plan.updated_at !== plan.created_at && (
              <span className="font-thai">
                แก้ไขล่าสุด: {new Date(plan.updated_at).toLocaleString('th-TH')}
              </span>
            )}
          </div>
        </div>

        {/* Footer */}
        <div className="flex items-center justify-end gap-3 px-6 py-4 border-t border-gray-200 bg-gray-50">
          <Button variant="outline" size="sm" onClick={onClose}>ปิด</Button>
        </div>
      </div>
    </div>
  );
}


// Create Plan Modal Component
function CreatePlanModal({ onClose, onSuccess }: { onClose: () => void; onSuccess: () => void }) {
  const { skus, isLoading: loadingSkus } = useSkusWithBom();
  const { createPlan, isLoading: creating, error: createError } = useProductionPlanMutations();
  const { calculate, result: bomResult, isLoading: calculating, reset: resetBom } = useBomCalculation();

  const [planName, setPlanName] = useState('');
  const [planDescription, setPlanDescription] = useState('');
  const [startDate, setStartDate] = useState(new Date().toISOString().split('T')[0]);
  const [endDate, setEndDate] = useState(new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0]);
  const [selectedSku, setSelectedSku] = useState('');
  const [quantity, setQuantity] = useState<number>(0);
  const [items, setItems] = useState<{ sku_id: string; sku_name: string; required_qty: number; materials: (CalculatedMaterial & { selected: boolean })[] }[]>([]);
  const [selectedMaterials, setSelectedMaterials] = useState<Record<string, boolean>>({});

  // Auto-generate plan name on mount
  useEffect(() => {
    const fetchNextPlanName = async () => {
      try {
        const response = await fetch('/api/production/planning/next-plan-name');
        const data = await response.json();
        if (data.data) {
          setPlanName(data.data);
        }
      } catch (error) {
        console.error('Error fetching next plan name:', error);
      }
    };
    fetchNextPlanName();
  }, []);

  // Auto-calculate BOM when SKU and quantity change
  useEffect(() => {
    if (selectedSku && quantity > 0) {
      calculate({ sku_id: selectedSku, quantity });
    } else {
      resetBom();
      setSelectedMaterials({});
    }
  }, [selectedSku, quantity]);

  // Initialize all materials as selected when BOM result changes
  useEffect(() => {
    if (bomResult && bomResult.materials.length > 0) {
      const initialSelection: Record<string, boolean> = {};
      bomResult.materials.forEach(mat => {
        initialSelection[mat.material_sku_id] = true;
      });
      setSelectedMaterials(initialSelection);
    }
  }, [bomResult]);

  const toggleMaterial = (materialSkuId: string) => {
    setSelectedMaterials(prev => ({
      ...prev,
      [materialSkuId]: !prev[materialSkuId]
    }));
  };

  const toggleAllMaterials = (selected: boolean) => {
    if (bomResult) {
      const newSelection: Record<string, boolean> = {};
      bomResult.materials.forEach(mat => {
        newSelection[mat.material_sku_id] = selected;
      });
      setSelectedMaterials(newSelection);
    }
  };

  const handleAddItem = () => {
    if (!selectedSku || quantity <= 0 || !bomResult) return;

    const sku = skus.find(s => s.sku_id === selectedSku);
    const materialsWithSelection = bomResult.materials.map(mat => ({
      ...mat,
      selected: selectedMaterials[mat.material_sku_id] ?? true
    }));

    setItems(prev => [...prev, {
      sku_id: selectedSku,
      sku_name: sku?.sku_name || selectedSku,
      required_qty: quantity,
      materials: materialsWithSelection,
    }]);
    setSelectedSku('');
    setQuantity(0);
    resetBom();
    setSelectedMaterials({});
  };

  const handleRemoveItem = (index: number) => {
    setItems(prev => prev.filter((_, i) => i !== index));
  };

  const handleSubmit = async () => {
    if (!planName || items.length === 0) return;

    const input: CreateProductionPlanInput = {
      plan_name: planName,
      plan_description: planDescription,
      plan_start_date: startDate,
      plan_end_date: endDate,
      items: items.map(item => ({
        sku_id: item.sku_id,
        required_qty: item.required_qty,
      })),
    };

    const result = await createPlan(input);
    if (result) {
      onSuccess();
    }
  };

  return (
    <div className="fixed inset-0 bg-black/50 flex items-center justify-center z-50">
      <div className="bg-white rounded-xl shadow-xl w-full max-w-4xl max-h-[90vh] overflow-hidden">
        {/* Header */}
        <div className="flex items-center justify-between px-6 py-4 border-b border-gray-200 bg-gradient-to-r from-primary-500 to-primary-600">
          <h2 className="text-lg font-bold text-white font-thai">สร้างแผนการผลิตใหม่</h2>
          <button onClick={onClose} className="p-1 hover:bg-white/20 rounded-lg transition-colors">
            <X className="w-5 h-5 text-white" />
          </button>
        </div>

        {/* Content */}
        <div className="p-6 overflow-y-auto max-h-[calc(90vh-140px)]">
          {/* Plan Info */}
          <div className="grid grid-cols-2 gap-4 mb-6">
            <div className="col-span-2">
              <label className="block text-sm font-medium text-gray-700 font-thai mb-1">ชื่อแผน *</label>
              <input
                type="text"
                value={planName}
                onChange={(e) => setPlanName(e.target.value)}
                placeholder="เช่น แผนผลิตประจำสัปดาห์ที่ 52"
                className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-thai focus:outline-none focus:ring-2 focus:ring-primary-500/50"
              />
            </div>
            <div className="col-span-2">
              <label className="block text-sm font-medium text-gray-700 font-thai mb-1">รายละเอียด</label>
              <textarea
                value={planDescription}
                onChange={(e) => setPlanDescription(e.target.value)}
                placeholder="รายละเอียดเพิ่มเติม..."
                rows={2}
                className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-thai focus:outline-none focus:ring-2 focus:ring-primary-500/50"
              />
            </div>
            <div>
              <label className="block text-sm font-medium text-gray-700 font-thai mb-1">วันที่เริ่ม *</label>
              <input
                type="date"
                value={startDate}
                onChange={(e) => setStartDate(e.target.value)}
                className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500/50"
              />
            </div>
            <div>
              <label className="block text-sm font-medium text-gray-700 font-thai mb-1">วันที่สิ้นสุด *</label>
              <input
                type="date"
                value={endDate}
                onChange={(e) => setEndDate(e.target.value)}
                className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500/50"
              />
            </div>
          </div>

          {/* Add Item Section */}
          <div className="bg-gray-50 rounded-lg p-4 mb-6">
            <h3 className="text-sm font-semibold text-gray-700 font-thai mb-3">เพิ่มสินค้าที่ต้องการผลิต</h3>
            <div className="flex items-end gap-3">
              <div className="flex-1">
                <label className="block text-xs text-gray-600 font-thai mb-1">เลือก SKU</label>
                <select
                  value={selectedSku}
                  onChange={(e) => setSelectedSku(e.target.value)}
                  className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-thai focus:outline-none focus:ring-2 focus:ring-primary-500/50"
                  disabled={loadingSkus}
                >
                  <option value="">-- เลือกสินค้า --</option>
                  {skus.map(sku => (
                    <option key={sku.sku_id} value={sku.sku_id}>{sku.sku_name} ({sku.sku_id})</option>
                  ))}
                </select>
              </div>
              <div className="w-32">
                <label className="block text-xs text-gray-600 font-thai mb-1">จำนวน</label>
                <input
                  type="number"
                  value={quantity || ''}
                  onChange={(e) => setQuantity(parseInt(e.target.value) || 0)}
                  placeholder="0"
                  min="1"
                  className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500/50"
                />
              </div>
              <Button
                variant="primary"
                size="sm"
                icon={Plus}
                onClick={handleAddItem}
                disabled={!selectedSku || quantity <= 0 || calculating || !bomResult}
                className="text-xs"
              >
                {calculating ? 'กำลังคำนวณ...' : 'เพิ่ม'}
              </Button>
            </div>

            {/* BOM Preview with Checkboxes */}
            {calculating && (
              <div className="mt-4 p-4 bg-white rounded-lg border border-gray-200 flex items-center justify-center">
                <Loader2 className="w-5 h-5 animate-spin text-primary-500 mr-2" />
                <span className="text-sm text-gray-600 font-thai">กำลังคำนวณวัตถุดิบ...</span>
              </div>
            )}

            {bomResult && bomResult.materials.length > 0 && !calculating && (
              <div className="mt-4 p-4 bg-white rounded-lg border border-gray-200">
                <div className="flex items-center justify-between mb-3">
                  <h4 className="text-sm font-semibold text-gray-700 font-thai">
                    วัตถุดิบที่ต้องใช้ ({bomResult.materials.length} รายการ)
                  </h4>
                  <div className="flex items-center gap-2">
                    <button
                      onClick={() => toggleAllMaterials(true)}
                      className="text-xs text-primary-600 hover:text-primary-700 font-thai"
                    >
                      เลือกทั้งหมด
                    </button>
                    <span className="text-gray-300">|</span>
                    <button
                      onClick={() => toggleAllMaterials(false)}
                      className="text-xs text-gray-500 hover:text-gray-700 font-thai"
                    >
                      ยกเลิกทั้งหมด
                    </button>
                  </div>
                </div>
                <div className="space-y-2 max-h-48 overflow-y-auto">
                  {bomResult.materials.map((mat, idx) => (
                    <label
                      key={idx}
                      className={`flex items-center gap-3 p-2 rounded-lg border cursor-pointer transition-colors ${
                        selectedMaterials[mat.material_sku_id]
                          ? 'bg-primary-50 border-primary-200'
                          : 'bg-gray-50 border-gray-200 opacity-60'
                      }`}
                    >
                      <input
                        type="checkbox"
                        checked={selectedMaterials[mat.material_sku_id] ?? true}
                        onChange={() => toggleMaterial(mat.material_sku_id)}
                        className="w-4 h-4 text-primary-600 border-gray-300 rounded focus:ring-primary-500"
                      />
                      <div className="flex-1 min-w-0">
                        <div className="flex items-center justify-between">
                          <span className="text-sm font-thai text-gray-800 truncate">{mat.material_name}</span>
                          <span className="text-xs font-mono text-gray-500 ml-2">{mat.material_sku_id}</span>
                        </div>
                        <div className="flex items-center justify-between mt-1">
                          <span className="text-xs text-gray-600">
                            ต้องใช้: <span className="font-semibold">{mat.gross_requirement.toLocaleString()}</span> {mat.material_uom}
                          </span>
                          <div className="flex items-center gap-2">
                            <span className="text-xs text-gray-500">
                              สต็อก: {mat.current_stock.toLocaleString()}
                            </span>
                            {mat.has_shortage && (
                              <span className="text-xs text-red-600 font-semibold bg-red-50 px-1.5 py-0.5 rounded">
                                ขาด {mat.shortage_qty.toLocaleString()}
                              </span>
                            )}
                          </div>
                        </div>
                      </div>
                    </label>
                  ))}
                </div>
                {bomResult.has_shortage && (
                  <div className="mt-3 p-2 bg-red-50 border border-red-200 rounded-lg">
                    <div className="flex items-center gap-2 text-red-700">
                      <AlertTriangle className="w-4 h-4" />
                      <span className="text-xs font-thai">
                        มีวัตถุดิบขาด {bomResult.shortage_count} รายการ
                      </span>
                    </div>
                  </div>
                )}
              </div>
            )}

            {bomResult && bomResult.materials.length === 0 && !calculating && selectedSku && (
              <div className="mt-4 p-4 bg-yellow-50 rounded-lg border border-yellow-200">
                <div className="flex items-center gap-2 text-yellow-700">
                  <AlertTriangle className="w-4 h-4" />
                  <span className="text-sm font-thai">ไม่พบข้อมูล BOM สำหรับสินค้านี้</span>
                </div>
              </div>
            )}
          </div>

          {/* Items List */}
          {items.length > 0 && (
            <div className="mb-6">
              <h3 className="text-sm font-semibold text-gray-700 font-thai mb-3">รายการสินค้าที่เลือก ({items.length})</h3>
              <div className="space-y-2">
                {items.map((item, index) => (
                  <div key={index} className="bg-white border border-gray-200 rounded-lg p-3">
                    <div className="flex items-center justify-between">
                      <div>
                        <span className="text-sm font-semibold text-gray-900 font-thai">{item.sku_name}</span>
                        <span className="text-xs text-gray-500 ml-2 font-mono">({item.sku_id})</span>
                      </div>
                      <div className="flex items-center gap-3">
                        <span className="text-sm font-bold text-blue-600">{item.required_qty.toLocaleString()} ชิ้น</span>
                        <button onClick={() => handleRemoveItem(index)} className="p-1 hover:bg-red-50 rounded text-red-500">
                          <Trash2 className="w-4 h-4" />
                        </button>
                      </div>
                    </div>
                    {item.materials.length > 0 && (
                      <div className="mt-2 pt-2 border-t border-gray-100">
                        <span className="text-xs text-gray-500 font-thai">วัตถุดิบ: {item.materials.length} รายการ</span>
                        {item.materials.some(m => m.has_shortage) && (
                          <span className="text-xs text-red-500 font-thai ml-2">
                            (ขาด {item.materials.filter(m => m.has_shortage).length} รายการ)
                          </span>
                        )}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </div>
          )}

          {createError && (
            <div className="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700 font-thai">
              {createError}
            </div>
          )}
        </div>

        {/* Footer */}
        <div className="flex items-center justify-end gap-3 px-6 py-4 border-t border-gray-200 bg-gray-50">
          <Button variant="outline" size="sm" onClick={onClose}>ยกเลิก</Button>
          <Button
            variant="primary"
            size="sm"
            icon={Check}
            onClick={handleSubmit}
            disabled={!planName || items.length === 0 || creating}
          >
            {creating ? 'กำลังสร้าง...' : 'สร้างแผน'}
          </Button>
        </div>
      </div>
    </div>
  );
}

export default function ProductionPlanningPageWithPermission() {
  return (
    <PermissionGuard
      permission="production.planning.view"
      fallback={
        <div className="flex items-center justify-center min-h-[400px]">
          <div className="text-center">
            <AlertTriangle className="h-12 w-12 text-red-500 mx-auto mb-4" />
            <h2 className="text-xl font-semibold text-gray-900 mb-2">ไม่มีสิทธิ์เข้าถึง</h2>
            <p className="text-gray-600">คุณไม่มีสิทธิ์ในการดูข้อมูลวางแผนผลิต</p>
          </div>
        </div>
      }
    >
      <ProductionPlanningPage />
    </PermissionGuard>
  );
}
